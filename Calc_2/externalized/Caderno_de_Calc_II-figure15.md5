\begingroup \toks 0={macro:-> \begin {axis}[ xmin=0, xmax=3, ymin=-0.5, ymax=2.5, axis x line=middle, axis y line=middle, tick align=outside, xtick=\empty , minor tick num=1, grid=both, axis line style={-{Stealth[length=3mm,width=1.5mm]}} ] \addplot [red, thick, domain=0.5:2.5, samples=200]{0.5*(x-2)^2+1}; \node at (0.5,-0.25) {a}; \node at (2.5,-0.25) {b}; \draw [blue, thick, dashed] (axis cs:0.5,0) -- (axis cs:0.5,2.1); \draw [blue, thick, dashed] (axis cs:2.5,0) -- (axis cs:2.5,1.1); \end {axis} }\xdef \tikzexternallastkey {\the \toks 0 }\endgroup %
