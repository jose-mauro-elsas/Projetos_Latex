\begingroup \toks 0={macro:-> \begin {axis}[ xmin=-1, xmax=4, ymin=-1, ymax=3, axis x line=middle, axis y line=middle, axis line style={-}, tick align=outside, grid=both, minor tick num=1, xlabel={$x$}, ylabel={$y$}, title={Superfície Geratriz} ] \addplot [ thick ] coordinates { (0.5,0.5) (3,0.5) (3,2) (0.5,2) (0.5,0.5) }; \par \addplot [ fill=blue!15, draw=none ] coordinates { (0.5,0.5) (3,0.5) (3,2) (0.5,2) (0.5,0.5) }; \par \addplot [only marks, mark=*] coordinates { (0.5,0.5) (3,0.5) (3,2) (0.5,2) (0.5,0.5) }; \end {axis} }\xdef \tikzexternallastkey {\the \toks 0 }\endgroup %
