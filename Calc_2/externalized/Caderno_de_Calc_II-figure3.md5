\begingroup \toks 0={macro:-> \begin {axis}[ clip=false, axis x line=middle, axis y line=middle, axis line style={-{Stealth[length=3mm,width=1.5mm]}}, xmin=0, xmax=2*pi, ymin=-0.5, ymax=1.2, grid=both, ytick={0.25, .5, .75, 1}, xtick=\empty , xticklabels=\empty , ] \par \addplot [ thick, blue, samples=200, domain=pi/2:3*pi/2, name path=curva ] {sin(deg(0.5*x))}; \par \path [name path=xaxis] (axis cs:{pi/2},0) -- (axis cs:{3*pi/2},0); \par \draw [blue, thick, dashed] (axis cs:{pi/2},0) -- (axis cs:{pi/2},{sqrt(2)/2}); \draw [blue, thick, dashed] (axis cs:{1.5*pi/2},0) -- (axis cs:{1.5*pi/2},0.923); \draw [blue, thick, dashed] (axis cs:{3*pi/2},0) -- (axis cs:{3*pi/2},{sqrt(2)/2}); \par \addplot [fill=gray!35, draw=none, opacity=.5] fill between[of=curva and xaxis, soft clip={domain=pi/2:1.5*pi/2}]; \node [anchor=north, yshift=-2pt] at (axis cs:{pi/2},0) {$a$}; \node [anchor=north, yshift=-2pt] at (axis cs:{1.5*pi/2},0) {$x$}; \node [anchor=north, yshift=-2pt] at (axis cs:{3*pi/2},0) {$b$}; \end {axis} }\xdef \tikzexternallastkey {\the \toks 0 }\endgroup %
