\begingroup \toks 0={macro:-> \begin {axis} [xmin=-3, xmax=1.5, ymin=-5, ymax=2, axis x line=middle, axis y line=middle, tick align=outside, minor tick num=1, grid=none, axis line style={-{Stealth[length=3mm,width=1.5mm]}}, ] \addplot [red, thick, domain=-2.5:1.5, samples=200, name path=vermelho]{x^2-4}; \addplot [blue, thick, domain=-2.5:1.5, samples=200, name path=azul]{-x^2-2*x}; \par \addplot [fill=gray!20, opacity=0.5, draw=none] fill between[of=vermelho and azul, soft clip={domain=-2:1}]; \par \end {axis} }\xdef \tikzexternallastkey {\the \toks 0 }\endgroup %
